# Required: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override the model (default: claude-sonnet-4-20250514)
# MODEL_ID=claude-sonnet-4-20250514

# Optional: Max tokens for agent responses (default: 8192)
# MAX_TOKENS=8192

# Optional: Detection tuning
# STALE_THRESHOLD_MINUTES=120
# OUTLIER_Z_THRESHOLD=2.0
# MIN_EDGE_PCT=1.0

# Optional: CORS allowed origins (comma-separated, default: http://localhost:3000)
# For production, set to your frontend URL
# CORS_ORIGINS=https://your-frontend.vercel.app

# Optional: Debug mode
# DEBUG=true
